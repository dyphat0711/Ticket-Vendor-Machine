@{
    ViewBag.Title = "Chọn Phương Thức Thanh Toán";

    // Lấy dữ liệu từ Controller gửi sang thông qua TempData
    string destName = TempData.Peek("DestName") as string ?? "Không xác định";
    decimal price = TempData.Peek("Price") != null ? Convert.ToDecimal(TempData.Peek("Price")) : 0;
}

<div class="container" style="margin-top: 50px;">
    <div class="text-center mb-5">
        <h2 style="color: #003366; font-weight: bold; font-size: 36px;">CHỌN PHƯƠNG THỨC THANH TOÁN</h2>
        <p class="text-muted" style="font-size: 1.2rem;">Vui lòng kiểm tra lại thông tin và chọn hình thức thanh toán</p>

        <div class="card mx-auto shadow-sm mt-4" style="max-width: 600px; border-radius: 15px; border-left: 8px solid #003366;">
            <div class="card-body">
                <h5 class="text-muted text-uppercase mb-3">Tuyến đường đã chọn</h5>
                <h2 style="color: #003366; font-weight: bold;">
                    <i class="fa fa-subway text-info"></i> @destName
                </h2>
                <hr />
                <div class="d-flex justify-content-between align-items-center px-3">
                    <h4 class="text-muted mb-0">Tổng thanh toán:</h4>
                    <h2 style="color: #28a745; font-weight: bold; margin-bottom: 0;">
                        @String.Format("{0:N0}", price) VND
                    </h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row justify-content-center mt-5 gap-4">

        <div class="col-md-5 mb-4">
            <form action="/Tickets/CreditCardPayment" method="post">
                <input type="hidden" name="method" value="CreditCard" />
                <button type="submit" class="btn btn-light w-100 shadow-sm payment-card"
                        style="border: 2px solid #e0e0e0; border-radius: 15px; padding: 50px 20px;">
                    <i class="fa fa-credit-card" style="font-size: 80px; color: #003366; margin-bottom: 20px;"></i>
                    <h2 style="color: #003366; font-weight: bold;">Credit Card</h2>
                    <p class="text-muted" style="font-size: 20px; margin-bottom: 0;">Thanh toán bằng Visa/Mastercard</p>
                </button>
            </form>
        </div>

        <div class="col-md-5 mb-4">
            <form action="/Tickets/SelectWallet" method="post">
                <button type="submit" class="btn btn-light w-100 shadow-sm payment-card"
                        style="border: 2px solid #e0e0e0; border-radius: 15px; padding: 50px 20px;">
                    <i class="fa fa-qrcode" style="font-size: 80px; color: #a50064; margin-bottom: 20px;"></i>
                    <h2 style="color: #a50064; font-weight: bold;">Digital Wallet / QR</h2>
                    <p class="text-muted" style="font-size: 20px; margin-bottom: 0;">Thanh toán bằng Momo, VNPay, ZaloPay</p>
                </button>
            </form>
        </div>

    </div>

    <div class="text-center mt-5">
        <button onclick="window.history.back();" class="btn btn-outline-primary btn-lg rounded-pill px-4">
            <i class="fa fa-arrow-left"></i> Quay lại
        </button>
        <a href="/Tickets/Index" class="btn btn-outline-danger btn-lg" style="border-radius: 50px; padding: 15px 50px; font-weight: bold; font-size: 20px;">

            <i class="fa fa-times-circle"></i> Hủy giao dịch
        </a>
    </div>
</div>

<style>
    .payment-card {
        transition: all 0.3s ease;
        background-color: #ffffff;
    }

        .payment-card:hover {
            border-color: #003366 !important;
            background-color: #f0f8ff !important;
            transform: translateY(-8px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.15) !important;
        }
</style>