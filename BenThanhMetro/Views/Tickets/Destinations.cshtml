@model IEnumerable<BenThanhMetro.Models.Destination>

@{
    ViewBag.Title = "Chọn Điểm Đến";
}

<div class="container" style="margin-top: 50px;">
    <div class="text-center mb-5">
        <h2 style="color: #003366; font-weight: bold; font-size: 36px;">GA ĐẾN</h2>
        <p class="text-muted" style="font-size: 1.2rem;">Vui lòng chạm để chọn ga bạn muốn đến</p>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <form action="/Tickets/PaymentMethod" method="post">
                        <input type="hidden" name="destId" value="@item.DestinationID" />
                        <input type="hidden" name="destName" value="@item.Name" />
                        <input type="hidden" name="price" value="@item.FareAmount" />

                        <button type="submit" class="btn btn-light w-100 p-4 shadow-sm destination-card"
                                style="border: 2px solid #e0e0e0; border-radius: 15px; text-align: left; transition: all 0.3s ease;">
                            <h4 style="color: #003366; font-weight: bold; margin-bottom: 10px;">
                                <i class="fa fa-map-marker text-danger"></i> @item.Name
                            </h4>
                            <h5 style="color: #28a745; margin: 0; font-weight: bold;">
                                @String.Format("{0:N0}", item.FareAmount) VND
                            </h5>
                        </button>
                    </form>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center">
                <p style="color: red;">Không tìm thấy tuyến đường nào trong CSDL!</p>
            </div>
        }
    </div>

    <div class="text-center mt-5">
        <button onclick="window.history.back();" class="btn btn-outline-primary btn-lg rounded-pill px-4">
            <i class="fa fa-arrow-left"></i> Quay lại
        </button>
        <a href="/Tickets/Index" class="btn btn-outline-secondary btn-lg" style="border-radius: 50px; padding: 12px 40px; font-weight: bold;">

            <i class="fa fa-times"></i> Hủy giao dịch
        </a>
    </div>
</div>

<style>
    .destination-card:hover {
        border-color: #28a745 !important;
        background-color: #f8fff9 !important;
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>