@{
    ViewBag.Title = "Quét mã QR";
    decimal price = Convert.ToDecimal(TempData.Peek("Price"));
    string walletType = ViewBag.WalletType ?? "VNPay";
}

<div class="container text-center" style="margin-top: 50px;">
    <h2 style="color: #003366; font-weight: bold;">THANH TOÁN @walletType.ToUpper()</h2>
    <p class="text-muted" style="font-size: 1.2rem;">Mở ứng dụng ví điện tử hoặc ngân hàng để quét mã</p>

    <div class="card mx-auto shadow-sm my-4" style="max-width: 400px; border-radius: 15px;">
        <div class="card-body p-4">
            <img src="https://api.qrserver.com/v1/create-qr-code/?size=250x250&data=DemoPayment_MetroTicket" alt="QR Code" class="img-fluid mb-3" />

            <h3 class="text-success font-weight-bold">@String.Format("{0:N0}", price) VND</h3>
            <p class="text-danger fw-bold"><i class="fa fa-clock-o"></i> Mã hết hạn sau: <span id="countdown">03:00</span></p>
        </div>
    </div>

    <form action="/Tickets/Processing" method="post" class="mt-4">
        <input type="hidden" name="method" value="@walletType" />
        <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow" style="background-color: #003366;">
            [Demo] Giả lập khách đã quét QR xong
        </button>
    </form>

    <div class="mt-4">
        <a href="/Tickets/Index" class="btn btn-outline-danger px-4 rounded-pill">Hủy Giao Dịch</a>
    </div>
</div>

<script>
    let timeLeft = 180; // 3 phút
    setInterval(function() {
        if (timeLeft <= 0) window.location.href = '/Tickets/Index'; // Hết giờ tự quay về Home
        timeLeft--;
        let m = Math.floor(timeLeft / 60).toString().padStart(2, '0');
        let s = (timeLeft % 60).toString().padStart(2, '0');
        document.getElementById("countdown").innerText = m + ":" + s;
    }, 1000);
</script>