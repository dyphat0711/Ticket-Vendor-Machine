@model IEnumerable<BenThanhMetro.Models.Payment>

@{
    ViewBag.Title = "Báo Cáo Doanh Thu Máy Bán Vé";
}

<div class="container-fluid" style="margin-top: 30px;">
    <h2 class="text-primary"><i class="fa fa-line-chart"></i> BÁO CÁO GIAO DỊCH & DOANH THU</h2>
    <p>Thống kê chi tiết các vé đã bán từ hệ thống Kiosk Ben Thanh Metro.</p>
    <hr />

    <table class="table table-bordered table-hover table-striped">
        <thead style="background-color: #2c3e50; color: white;">
            <tr>
                <th>Mã GD</th>
                <th>Thời Gian Mua</th>
                <th>Tuyến Đường</th>
                <th>Mã Vạch (Barcode)</th>
                <th>Máy Xuất Vé</th>
                <th>Số Tiền (VND)</th>
                <th>Hình Thức</th>
                <th>Trạng Thái</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="text-center"><strong>#@item.PaymentID</strong></td>
                    <td>@(item.PaymentDate.HasValue ? item.PaymentDate.Value.ToString("dd/MM/yyyy HH:mm") : "")</td>

                    <td><strong class="text-info">@item.Ticket.Destination.Name</strong></td>

                    <td><span style="font-family: 'Courier New', Courier, monospace; background-color: #eee; padding: 2px 5px;">@item.Ticket.BarcodeData</span></td>

                    <td><small>@item.Ticket.TicketVendorMachine.Location</small></td>

                    <td class="text-right text-danger"><strong>@String.Format("{0:N0}", item.Amount)</strong></td>

                    <td>
                        @if (item.PaymentMethod == "Momo" || item.PaymentMethod == "VNPay" || item.PaymentMethod == "ZaloPay")
                        {
                            <span class="badge" style="background-color: #0088cc;">@item.PaymentMethod</span>
                        }
                        else
                        {
                            <span class="badge" style="background-color: #8e44ad;">@item.PaymentMethod</span>
                        }
                    </td>

                    <td>
                        @if (item.TransactionStatus == "Completed")
                        {
                            <span style="color: green; font-weight: bold;">✔ Thành công</span>
                        }
                        else
                        {
                            <span style="color: red; font-weight: bold;">✘ @item.TransactionStatus</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>